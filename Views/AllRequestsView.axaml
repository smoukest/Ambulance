<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ambulance.Views.AllRequestsView">

  <Grid Background="#32d1b4">
    <Border Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Height="50" Margin="0,0,0,15">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="Все заявки" FontSize="18" FontWeight="Bold" 
                     Foreground="Black" VerticalAlignment="Center"/>
          
          <!-- Search Button -->
          <Button Grid.Column="2" x:Name="SearchButton" Content="🔍" 
                  FontFamily="Segoe UI" Background="#ecfff8" FontSize="18"
                  Foreground="Black" Width="40" Height="40" Margin="0,0,10,0" 
                  BorderBrush="#333" VerticalAlignment="Center" 
                  HorizontalAlignment="Right" Click="Search_click"/>
        </Grid>

        <!-- Filters Panel -->
        <Border Grid.Row="1" Background="#ecfff8" CornerRadius="4" 
                Padding="10" Margin="0,0,0,15">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="100"/>
              <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            
            <!-- № Заявки -->
            <TextBox x:Name="FilterRequestNumber" Watermark="№ заявки" 
                     Background="#d1ffef" BorderBrush="#333" 
                     VerticalAlignment="Center" Margin="5" Padding="5" 
                     FontSize="12" Foreground="#666"/>
            
            <!-- ФИО/Адрес -->
            <TextBox x:Name="FilterPatient" Grid.Column="1" Watermark="ФИО/Адрес" 
                     Background="#d1ffef" BorderBrush="#333" 
                     VerticalAlignment="Center" Margin="5" Padding="5" 
                     FontSize="12" Foreground="#666"/>
            
            <!-- Телефон -->
            <TextBox x:Name="FilterPhone" Grid.Column="2" Watermark="Телефон" 
                     Background="#d1ffef" BorderBrush="#333" 
                     VerticalAlignment="Center" Margin="5" Padding="5" 
                     FontSize="12" Foreground="#666"/>
            
            <!-- Фильтр по Приоритету (Button + Flyout) -->
            <Button Grid.Column="3" x:Name="PriorityFilterButton" 
                    Background="#d1ffef" BorderBrush="#333" 
                    VerticalAlignment="Center" Margin="10,5" Height="28"
                    FontSize="12" Foreground="#666" HorizontalContentAlignment="Left"
                    Content="Приоритет" Click="PriorityFilterButton_Click"/>

            <!-- Фильтр по Статусу (Button + Flyout) -->
            <Button Grid.Column="4" x:Name="StatusFilterButton" 
                    Background="#d1ffef" BorderBrush="#333" 
                    VerticalAlignment="Center" Margin="10,5" Height="28"
                    FontSize="12" Foreground="#666" HorizontalContentAlignment="Left"
                    Content="Статус" Click="StatusFilterButton_Click"/>
            
            <!-- Время -->
            <DatePicker x:Name="FilterDate" Grid.Column="5" 
                        Background="#d1ffef" BorderBrush="#333" 
                        VerticalAlignment="Center" Margin="5" Height="28"/>
            
            <!-- Бригада -->
            <ComboBox x:Name="FilterBrigade" Grid.Column="6" 
                      Background="#d1ffef" BorderBrush="#333" 
                      VerticalAlignment="Center" Margin="5" Height="28" 
                      FontSize="12" Foreground="#666">
              <ComboBoxItem Content="Все"/>
              <ComboBoxItem Content="Бригада №1"/>
              <ComboBoxItem Content="Бригада №2"/>
              <ComboBoxItem Content="Бригада №3"/>
            </ComboBox>
          </Grid>
        </Border>

        <!-- Calls Table -->
        <ScrollViewer Grid.Row="2" x:Name="CallsScrollViewer" 
                      HorizontalScrollBarVisibility="Auto">
          <StackPanel x:Name="CallsContainer" Spacing="5"/>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>
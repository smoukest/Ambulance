<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="Ambulance.Views.AllRequestsView"
			 xmlns:vm="using:Ambulance.ViewModels"
			 xmlns:local="using:Ambulance.Views"
			 x:DataType="vm:AllRequestsViewModel">

	<UserControl.Resources>
      <local:PriorityToColorConverter x:Key="PriorityToColorConverter"/>
		<local:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
	</UserControl.Resources>

	<Grid Background="#32d1b4">
		<Border Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5">
			<Grid Grid.IsSharedSizeScope="True">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- Header -->
				<Grid Height="50" Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="Все заявки" FontSize="18" FontWeight="Bold"
							   Foreground="Black" VerticalAlignment="Center"/>

					<!-- Search Button -->
					<Button Grid.Column="2" Content="🔍" Click="SearchButton_Click"
							FontFamily="Segoe UI" Background="#ecfff8" FontSize="18"
							Foreground="Black" Width="40" Height="40" Margin="0,0,10,0"
							BorderBrush="#333" VerticalAlignment="Center"
							HorizontalAlignment="Right"/>
				</Grid>

				<!-- Table Header (Column Titles) -->
				<Border Grid.Row="1" Background="#4CAF50" CornerRadius="4" Padding="0" Margin="0,0,0,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col0"/>
							<ColumnDefinition Width="2*" SharedSizeGroup="Col1"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col2"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col3"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col4"/>
						</Grid.ColumnDefinitions>

						<TextBlock Text="№ Заявки" Foreground="White" FontWeight="Bold" FontSize="12" 
								   VerticalAlignment="Center" Margin="10,10"/>
						<TextBlock Grid.Column="1" Text="ФИО и Контакты" Foreground="White" FontWeight="Bold" FontSize="12"
								   VerticalAlignment="Center" Margin="10,10"/>
						<TextBlock Grid.Column="2" Text="Приоритет" Foreground="White" FontWeight="Bold" FontSize="12"
								   VerticalAlignment="Center" Margin="10,10" TextAlignment="Center"/>
						<TextBlock Grid.Column="3" Text="Статус" Foreground="White" FontWeight="Bold" FontSize="12"
								   VerticalAlignment="Center" Margin="10,10" TextAlignment="Center"/>
						<TextBlock Grid.Column="4" Text="Время" Foreground="White" FontWeight="Bold" FontSize="12"
								   VerticalAlignment="Center" Margin="10,10"/>
					</Grid>
				</Border>

				<!-- Filters Panel -->
				<Border Grid.Row="2" Background="#ecfff8" CornerRadius="4"
						Padding="10" Margin="0,0,0,15">
					<StackPanel>
						<!-- Верхняя строка фильтров -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col0"/>
							<ColumnDefinition Width="2*" SharedSizeGroup="Col1"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col2"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col3"/>
							<ColumnDefinition Width="1*" SharedSizeGroup="Col4"/>
						</Grid.ColumnDefinitions>

							<!-- № Заявки -->
							<TextBox Text="{Binding FilterRequestNumber}" Watermark="№ заявки"
									 Background="#d1ffef" BorderBrush="#333"
									 VerticalAlignment="Center" VerticalContentAlignment="Center"
									 Margin="5" Padding="5" Height="28"
									 FontSize="12" Foreground="#666"/>

							<!-- Кнопка для открытия фильтра пациента -->
							<Button Grid.Column="1" Name="TogglePatientFilterButton" Content="Фильтр пациента" 
									Click="TogglePatientFilter_Click"
									Background="#d1ffef" BorderBrush="#333" Margin="5" Padding="5"
									FontSize="12" VerticalAlignment="Center" VerticalContentAlignment="Center"
									Height="28"/>


							<!-- Кнопка Приоритет -->
							<Button Grid.Column="2" Name="TogglePriorityFilterButton" Content="Выберите приоритет"
									Click="TogglePriorityFilter_Click"
									Background="#d1ffef" BorderBrush="#333" Margin="5" Padding="5"
									FontSize="12" VerticalAlignment="Center" VerticalContentAlignment="Center"
									Height="28"/>
							<!-- Popup для Приоритета -->
							<Popup Name="PriorityFilterPopup" PlacementMode="Bottom" PlacementTarget="{Binding #TogglePriorityFilterButton}">
								<Border Background="#d1ffef" CornerRadius="4" Padding="10" BorderBrush="#333" BorderThickness="2"
										BoxShadow="0 4 12 #00000033">
									<StackPanel>
										<TextBlock Text="Выберите приоритет:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8" FontSize="12"/>
										<ListBox ItemsSource="{Binding AvailablePriorities}" SelectionMode="Multiple" Background="Transparent" BorderThickness="0" Focusable="False">
											<ListBox.ItemTemplate>
												<DataTemplate>
													<StackPanel Orientation="Horizontal" Spacing="8">
														<Border Background="{Binding Name, Converter={StaticResource PriorityToColorConverter}}" CornerRadius="3" Width="16" Height="16" VerticalAlignment="Center"/>
														<CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Focusable="False" VerticalAlignment="Center"/>
													</StackPanel>
												</DataTemplate>
											</ListBox.ItemTemplate>
										</ListBox>
									</StackPanel>
								</Border>
							</Popup>

							<!-- Кнопка Статус -->
							<Button Grid.Column="3" Name="ToggleStatusFilterButton" Content="Выберите статус"
									Click="ToggleStatusFilter_Click"
									Background="#d1ffef" BorderBrush="#333" Margin="5" Padding="5"
									FontSize="12" VerticalAlignment="Center" VerticalContentAlignment="Center"
									Height="28"/>

							<!-- Popup для Статуса -->
							<Popup Name="StatusFilterPopup" PlacementMode="Bottom" PlacementTarget="{Binding #ToggleStatusFilterButton}">
								<Border Background="#d1ffef" CornerRadius="4" Padding="10" BorderBrush="#333" BorderThickness="2"
										BoxShadow="0 4 12 #00000033">
									<StackPanel>
										<TextBlock Text="Выберите статус:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,8" FontSize="12"/>
										<ListBox ItemsSource="{Binding AvailableStatuses}" SelectionMode="Multiple" Background="Transparent" BorderThickness="0" Focusable="False">
											<ListBox.ItemTemplate>
												<DataTemplate>
													<CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Focusable="False"/>
												</DataTemplate>
											</ListBox.ItemTemplate>
										</ListBox>
									</StackPanel>
								</Border>
							</Popup>

							<!-- Кнопка для выбора временного интервала -->
							<Button Grid.Column="4" Name="ToggleDateRangeFilterButton" Content="{Binding FilterDateRangeDisplay}"
									Click="ToggleDateRangeFilter_Click"
									Background="#d1ffef" BorderBrush="#333" Margin="5" Padding="5"
									FontSize="12" VerticalAlignment="Center" VerticalContentAlignment="Center"
									Height="28"/>

							<!-- Popup с календарём для выбора временного интервала -->
							<Popup Name="DateRangeFilterPopup" PlacementMode="Bottom" PlacementTarget="{Binding #ToggleDateRangeFilterButton}">
								<Border Background="#d1ffef" CornerRadius="4" Padding="15" BorderBrush="#333" BorderThickness="2"
										 BoxShadow="0 4 12 #00000033">
									<StackPanel>
										<TextBlock Text="Выберите период, кликнув на две даты:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10" FontSize="12"/>

										<!-- Индикаторы выбранных дат -->
										<StackPanel Name="DateIndicatorsPanel" Spacing="8" Margin="0,0,0,10" Orientation="Horizontal">
											<Border Name="FirstDateIndicator" Background="Transparent" CornerRadius="3" Padding="8,4" BorderBrush="#FFD700" BorderThickness="2" IsVisible="True">
												<StackPanel Orientation="Vertical" Spacing="2">
													<TextBlock Text="Первая дата:" Foreground="#FFB300" FontSize="10" FontWeight="Bold"/>
													<TextBlock Name="FirstDateText" Text="" Foreground="#333" FontSize="11"/>
												</StackPanel>
											</Border>

											<Border Name="SecondDateIndicator" Background="Transparent" CornerRadius="3" Padding="8,4" BorderBrush="#4CAF50" BorderThickness="2" IsVisible="True">
												<StackPanel Orientation="Vertical" Spacing="2">
													<TextBlock Text="Вторая дата:" Foreground="#2E7D32" FontSize="10" FontWeight="Bold"/>
													<TextBlock Name="SecondDateText" Text="" Foreground="#333" FontSize="11"/>
												</StackPanel>
											</Border>
										</StackPanel>

										<Calendar Name="DateRangePickerCalendar" Background="White" Margin="0,0,0,15"/>

										<StackPanel Spacing="10">
											<TextBlock Text="{Binding FilterDateRangeDisplay}" VerticalAlignment="Center" 
													   Foreground="#333" FontSize="11" Margin="0" FontWeight="Bold"/>
											<Button Content="Очистить" Click="ClearDateRange_Click"
													Background="#FF5252" Foreground="White" Padding="8,4" FontSize="11"/>
										</StackPanel>
									</StackPanel>
								</Border>
							</Popup>
									</Grid>

						<!-- Popup с полями фильтрации пациента -->
						<Popup Name="PatientFilterPopup" PlacementMode="Bottom" PlacementTarget="{Binding #TogglePatientFilterButton}">
							<Border Background="#d1ffef" CornerRadius="4" Padding="15" BorderBrush="#333" BorderThickness="2" 
									Width="350" BoxShadow="0 4 12 #00000033">
								<StackPanel>
									<TextBlock Text="Фильтр данных пациента:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

									<TextBlock Text="Фамилия:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
									<TextBox Name="SurnameFilter" Watermark="Введите фамилию" Background="White" BorderBrush="#333" Margin="0,0,0,10" Padding="5" FontSize="12" 
											 Text="{Binding FilterPatient}"/>

									<TextBlock Text="Имя:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
									<TextBox Name="FirstNameFilter" Watermark="Введите имя" Background="White" BorderBrush="#333" Margin="0,0,0,10" Padding="5" FontSize="12"/>

									<TextBlock Text="Отчество:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
									<TextBox Name="PatronymicFilter" Watermark="Введите отчество" Background="White" BorderBrush="#333" Margin="0,0,0,10" Padding="5" FontSize="12"/>

									<TextBlock Text="Номер телефона:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
									<TextBox Name="PhoneFilter" Watermark="Введите номер телефона" Background="White" BorderBrush="#333" Margin="0,0,0,10" Padding="5" FontSize="12"
											 Text="{Binding FilterPhone}"/>

									<TextBlock Text="Адрес:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
                                    <TextBox Name="AddressFilter" Watermark="Введите адрес" Background="White" BorderBrush="#333" Margin="0,0,0,10" Padding="5" FontSize="12"
											 Text="{Binding FilterAddress, Mode=TwoWay}"/>

									<TextBlock Text="Email:" Margin="0,5,0,2" Foreground="#333" FontSize="12"/>
                                    <TextBox Name="EmailFilter" Watermark="Введите email" Background="White" BorderBrush="#333" Margin="0,0,0,0" Padding="5" FontSize="12"
											 Text="{Binding FilterEmail, Mode=TwoWay}"/>
								</StackPanel>
							</Border>
						</Popup>
					</StackPanel>
				</Border>

				<!-- Calls Table -->
				<ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<ItemsControl ItemsSource="{Binding RequestRows}" HorizontalAlignment="Stretch">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Spacing="5" HorizontalAlignment="Stretch"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="vm:RequestRow">
								<Expander HorizontalContentAlignment="Stretch" BorderThickness="0" 
										 Background="#ffffff" Padding="0" Margin="0,0,0,3" HorizontalAlignment="Stretch">
									<Expander.Header>
										<Grid Background="#ecfff8" Height="50" HorizontalAlignment="Stretch">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="1*" SharedSizeGroup="Col0"/>
												<ColumnDefinition Width="2*" SharedSizeGroup="Col1"/>
												<ColumnDefinition Width="1*" SharedSizeGroup="Col2"/>
												<ColumnDefinition Width="1*" SharedSizeGroup="Col3"/>
												<ColumnDefinition Width="1*" SharedSizeGroup="Col4"/>
											</Grid.ColumnDefinitions>

											<!-- Номер заявки -->
											<TextBlock Text="{Binding CallId}" Foreground="#FF5252" FontWeight="Bold" Margin="10,0"
													   VerticalAlignment="Center" HorizontalAlignment="Left"/>

											<!-- ФИО + Телефон (клик открывает детали) -->
											<StackPanel Grid.Column="1" Margin="10,5" VerticalAlignment="Center" HorizontalAlignment="Stretch">
												<TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="#333" TextTrimming="CharacterEllipsis"/>
												<TextBlock Text="{Binding Phone}" FontSize="11" Foreground="#999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
											</StackPanel>

											<!-- Приоритет -->
											<Border Grid.Column="2" CornerRadius="4" Padding="5,2" Margin="10,5" Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center">
												<TextBlock Text="{Binding Priority}" Foreground="White" FontSize="12" TextAlignment="Center"
														   VerticalAlignment="Center"/>
											</Border>

											<!-- Статус -->
											<Border Grid.Column="3" CornerRadius="4" Padding="5,2" Margin="10,5" Background="#4CAF50" HorizontalAlignment="Center" VerticalAlignment="Center">
												<TextBlock Text="{Binding Status}" Foreground="White" FontSize="12" TextAlignment="Center"
														   VerticalAlignment="Center"/>
											</Border>

											<!-- Время -->
											<TextBlock Grid.Column="4" Text="{Binding Time}" Margin="10,0"
													   VerticalAlignment="Center" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
										</Grid>
									</Expander.Header>

									<!-- Детали (выпадающее содержимое) -->
									<Border Background="White" Padding="15" Margin="0">
                                        <Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
											</Grid.ColumnDefinitions>
               <Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

											<TextBlock Text="ID Пациента:" FontWeight="Bold" Foreground="#333" Margin="0,0,10,0"/>
											<TextBlock Grid.Column="1" Text="{Binding PatientId}" Foreground="#555" TextWrapping="Wrap"/>

              <TextBlock Grid.Row="1" Text="Email:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0" IsVisible="{Binding Email, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
				<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Email}" Foreground="#555" Margin="0,10,0,0" TextWrapping="Wrap" IsVisible="{Binding Email, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

				<TextBlock Grid.Row="2" Text="Адрес:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0"/>
				<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Address}" Foreground="#555" Margin="0,10,0,0" TextWrapping="Wrap"/>

				<TextBlock Grid.Row="3" Text="Дата рождения:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0" IsVisible="{Binding BirthDate, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
				<TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BirthDate}" Foreground="#555" Margin="0,10,0,0" TextWrapping="Wrap" IsVisible="{Binding BirthDate, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

				<TextBlock Grid.Row="4" Text="Пол:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0" IsVisible="{Binding Gender, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
				<TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Gender}" Foreground="#555" Margin="0,10,0,0" TextWrapping="Wrap" IsVisible="{Binding Gender, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

				<TextBlock Grid.Row="5" Text="Цель обращения:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0"/>
				<TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AppealPurpose}" Foreground="#555" 
					   Margin="0,10,0,0" TextWrapping="Wrap"/>

				<TextBlock Grid.Row="6" Text="Анамнез:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0"/>
				<TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Anamnesis}" Foreground="#555" 
					   Margin="0,10,0,0" TextWrapping="Wrap"/>

				<TextBlock Grid.Row="7" Text="Жалобы:" FontWeight="Bold" Foreground="#333" Margin="0,10,10,0"/>
				<TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Complaints}" Foreground="#555" 
					   Margin="0,10,0,0" TextWrapping="Wrap"/>
										</Grid>
									</Border>
								</Expander>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</UserControl>
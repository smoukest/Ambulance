<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ambulance.Views.RegistrationView">
   
    <Grid Background="#32d1b4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Registration Form -->
        <Border Grid.Column="0" Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5">
          <StackPanel>
            <TextBlock Text="Регистрация новой заявки" FontSize="20" FontWeight="Bold" 
                       Foreground="Black" Margin="0,0,0,20" />
        
            <Grid Margin="0,10" ColumnDefinitions="*,*">
              <TextBox Grid.Column="0" Watermark="Номер телефона" 
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40" 
                       Margin="0,0,10,0" Name="PhoneNumber"/>
              <TextBox Grid.Column="1" Watermark="Электронная почта"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40" Name="Email"/>
            </Grid>
        
            <Grid Margin="0,10" ColumnDefinitions="*,*,*">
              <TextBox Grid.Column="0" Watermark="Фамилия" 
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40" 
                       Margin="0,0,5,0" Name="Surname"/>
              <TextBox Grid.Column="1" Watermark="Имя"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40" 
                       Margin="0,0,5,0" Name="Name"/>
              <TextBox Grid.Column="2" Watermark="Отчество" Name="Patronymic"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40"/>
            </Grid>
        
            <TextBox Watermark="Адрес проживания" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="40" 
                     Margin="0,10,0,0" Name="Address"/>
        
            <TextBox Watermark="Анамнез" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="100" 
                     Margin="0,10,0,0" TextWrapping="Wrap" Name="Anamnesis"/>
        
            <TextBox Watermark="Жалобы" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="100" 
                     Margin="0,10,0,0" TextWrapping="Wrap" Name="Complaints"/>
            <Grid Margin="0,10,0,0" ColumnDefinitions="*,*">
                <ComboBox Grid.Column="0" Background="#ecfff8" Foreground="Black" Height="40" 
                          PlaceholderText="Цель обращения" Name="AppealPurpose" Margin="0,0,10,0">
                    <ComboBoxItem Content="Консультация"/>
                    <ComboBoxItem Content="Выезд"/>
                    <ComboBoxItem Content="Другая"/>
                </ComboBox>
        
                <Button Grid.Column="1" Content="Зарегистрировать заявку" Background="#4CAF50" Foreground="Black" 
                        Height="40" FontWeight="Bold" BorderBrush="Black" HorizontalAlignment="Right" Click="Registration_Click"/>
            </Grid>
            <Button Content="Очистить" Background="#FF5252" Foreground="Black" HorizontalAlignment="Right"
                    Height="40" Margin="0,50,0,0" BorderBrush="Black" FontWeight="Bold" Click="Clear_Click"/>
          </StackPanel>
        </Border>

        <!-- Recent Requests -->
        <Border Grid.Column="1" Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5">
          <StackPanel>
            <TextBlock Text="Последние заявки" FontSize="18" FontWeight="Bold" 
                       Foreground="Black" Margin="0,0,0,20"/>
        
            <Border Background="#ecfff8" CornerRadius="4" Padding="10" Margin="0,0,0,10">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                  <TextBlock Text="REQ-006" FontWeight="Bold" />
                  <TextBlock Text="Средний" Background="#FF9800" Foreground="Black" 
                             Padding="5,2" Margin="10,0"/>
                </StackPanel>
                <TextBlock Text="Морозова Ольга Петровна" FontWeight="Bold" Foreground="Black"/>
                <TextBlock Text="Боль в животе, тошнота" Foreground="#BDBDBD" FontSize="12"/>
                <TextBlock Text="г. Москва, ул. Новый Арбат, д. 30..." 
                           Foreground="#BDBDBD" FontSize="12" Margin="0,5,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <TextBlock Text="5 минут назад" Foreground="#BDBDBD" FontSize="12"/>
                </StackPanel>
              </StackPanel>
            </Border>
        
            <Border Background="#ecfff8" CornerRadius="4" Padding="10" Margin="0,0,0,10" >
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                  <TextBlock Text="REQ-003" FontWeight="Bold"/>
                  <TextBlock Text="Средний" Background="#FF9800" Foreground="Black" 
                             Padding="5,2" Margin="10,0"/>
                </StackPanel>
                <TextBlock Text="Козлов Алексей Викторович" FontWeight="Bold" Foreground="Black"/>
                <TextBlock Text="Травма ноги после падения, отек" 
                           Foreground="#BDBDBD" FontSize="12"/>
                <TextBlock Text="г. Москва, ул. Тверская, д. 25, кв. 8" 
                           Foreground="#BDBDBD" FontSize="12" Margin="0,5,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <TextBlock Text="8 минут назад" Foreground="#BDBDBD" FontSize="12"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </Grid>
</UserControl>
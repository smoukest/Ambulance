<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ambulance.Views.RegistrationView">
   
    <Grid Background="#32d1b4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Registration Form: пациент + параметры обращения -->
        <Border Grid.Column="0" Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5" HorizontalAlignment="Stretch">
          <StackPanel HorizontalAlignment="Stretch">
            <TextBlock Text="Регистрация новой заявки" FontSize="20" FontWeight="Bold" 
                       Foreground="Black" Margin="0,0,0,8" />
            

            <Grid Margin="0,4" ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
              <TextBox Grid.Column="0" Watermark="Номер телефона" 
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" 
                       Margin="0,0,8,0" Name="PhoneNumber"/>
              <TextBox Grid.Column="1" Watermark="Электронная почта"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" Name="Email"/>
            </Grid>

            <Grid Margin="0,4" ColumnDefinitions="*,*,*" HorizontalAlignment="Stretch">
              <TextBox Grid.Column="0" Watermark="Фамилия" 
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" 
                       Margin="0,0,4,0" Name="Surname"/>
              <TextBox Grid.Column="1" Watermark="Имя"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" 
                       Margin="0,0,4,0" Name="Name"/>
              <TextBox Grid.Column="2" Watermark="Отчество" Name="Patronymic"
                       Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32"/>
            </Grid>

            <Grid Margin="0,4" ColumnDefinitions="3*,*" HorizontalAlignment="Stretch">
                <TextBox Grid.Column="0" Watermark="Дата рождения (дд.мм.гггг)" 
                         Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" 
                         Margin="0,0,8,0" Name="BirthDate" HorizontalAlignment="Stretch"/>
                <ComboBox Grid.Column="1" Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32"
                          Name="Gender" PlaceholderText="Пол" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Мужской"/>
                    <ComboBoxItem Content="Женский"/>
                </ComboBox>
            </Grid>

            <TextBox Watermark="Адрес проживания" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="32" 
                     Margin="0,4,0,0" Name="Address"/>

            <TextBox Watermark="Анамнез" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="72" 
                     Margin="0,4,0,0" TextWrapping="Wrap" Name="Anamnesis"/>

            <TextBox Watermark="Жалобы" 
                     Background="#ecfff8" Foreground="Black" BorderBrush="#333" Height="72" 
                     Margin="0,4,0,0" TextWrapping="Wrap" Name="Complaints"/>
            <Grid Margin="0,8,0,0" ColumnDefinitions="*,*">
                <ComboBox Grid.Column="0" Background="#ecfff8" Foreground="Black" Height="32" 
                          PlaceholderText="Цель обращения" Name="AppealPurpose" Margin="0,0,8,0">
                    <ComboBoxItem Content="Консультация"/>
                    <ComboBoxItem Content="Выезд"/>
                    <ComboBoxItem Content="Другая"/>
                </ComboBox>

                <Button Grid.Column="1" Content="Зарегистрировать заявку" Background="#4CAF50" Foreground="Black" 
                        Height="32" FontWeight="Bold" BorderBrush="Black" HorizontalAlignment="Right" Click="Registration_Click"/>
            </Grid>
            <Button Content="Очистить" Background="#FF5252" Foreground="Black" HorizontalAlignment="Right"
                    Height="32" Margin="0,16,0,0" BorderBrush="Black" FontWeight="Bold" Click="Clear_Click"/>
          </StackPanel>
        </Border>

        <!-- Правая панель: краткая информация -->
        
      </Grid>
</UserControl>
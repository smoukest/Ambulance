<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ambulance.Views.StatisticsView"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:Ambulance.ViewModels"
             x:DataType="vm:StatisticsViewModel">

  <Grid Background="#32d1b4">
    <Border Background="#d1ffef" CornerRadius="8" Padding="20" Margin="5">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stat Cards -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*" Margin="0,0,0,15">
          <!-- Card 1 -->
          <Border Grid.Column="0" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="Всего заявок" FontSize="14" Foreground="#666"/>
              <TextBlock Text="{Binding TotalCalls}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
              <TextBlock Text="" FontSize="12" Foreground="#4CAF50"/>
            </StackPanel>
          </Border>
          <!-- Card 2 -->
          <Border Grid.Column="1" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="Завершено сегодня" FontSize="14" Foreground="#666"/>
              <TextBlock Text="{Binding CompletedToday}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
              <TextBlock Text="" FontSize="12" Foreground="#4CAF50"/>
            </StackPanel>
          </Border>
          <!-- Card 3 -->
          <Border Grid.Column="2" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="В работе" FontSize="14" Foreground="#666"/>
              <TextBlock Text="{Binding InProgress}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
              <TextBlock Text="" FontSize="12" Foreground="#4CAF50"/>
            </StackPanel>
          </Border>
          <!-- Card 4 -->
          <Border Grid.Column="3" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="Критические" FontSize="14" Foreground="#666"/>
              <TextBlock Text="{Binding CriticalCalls}" FontSize="24" FontWeight="Bold" Foreground="Black"/>
              <TextBlock Text="" FontSize="12" Foreground="#F44336"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Charts Row -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,15">
          <!-- Chart 1 -->
          <Border Grid.Column="0" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Заявки по часам" FontSize="16" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding HourlyPeriods}" SelectedItem="{Binding SelectedHourlyPeriod}" Width="120" VerticalAlignment="Center" />
              </Grid>
              <!-- Line Chart -->
              <Grid Height="200" Background="Transparent">
                <lvc:CartesianChart Series="{Binding HourlySeries}" XAxes="{Binding HourlyXAxes}" />
              </Grid>
            </StackPanel>
          </Border>
          
          <!-- Chart 2 -->
          <Border Grid.Column="1" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="Статистика за неделю" FontSize="16" FontWeight="Bold" 
                         Foreground="Black" Margin="0,0,0,10"/>
              <!-- Column Chart -->
              <Grid Height="200">
                <lvc:CartesianChart Series="{Binding WeeklySeries}" XAxes="{Binding WeeklyXAxes}" LegendPosition="Bottom"/>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Bottom Row -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Margin="0,0,0,15">
          <!-- Chart 3 -->
          <Border Grid.Column="0" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="По статусу" FontSize="16" FontWeight="Bold" Foreground="Black" 
                         Margin="0,0,0,10"/>
              <!-- Pie Chart Mock -->
              <Grid Height="250" Margin="0,10">
                <lvc:PieChart Series="{Binding StatusSeries}" LegendPosition="Right" />
              </Grid>
            </StackPanel>
          </Border>
          
          <!-- Chart 4 -->
          <Border Grid.Column="1" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="По приоритету" FontSize="16" FontWeight="Bold" Foreground="Black" 
                         Margin="0,0,0,10"/>
              <!-- Pie Chart Mock -->
              <Grid Height="250" Margin="0,10">
                <lvc:PieChart Series="{Binding PrioritySeries}" LegendPosition="Right" />
              </Grid>
            </StackPanel>
          </Border>
          
          <!-- Brigades -->
          <Border Grid.Column="2" Background="#ecfff8" CornerRadius="8" 
                  Padding="15" Margin="5">
            <StackPanel>
              <TextBlock Text="Бригады" FontSize="16" FontWeight="Bold" Foreground="Black" 
                         Margin="0,0,0,10"/>
              <StackPanel Margin="0,10">
                <Border Background="#d1ffef" CornerRadius="4" Padding="10" Margin="0,5">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Бригада №1" FontWeight="Bold" Foreground="Black"/>
                    <TextBlock Text="12 вызовов" Foreground="#666" Margin="10,0,0,0"/>
                    <TextBlock Text="В пути" Foreground="#FF9800" FontWeight="Bold" Margin="10,0,0,0"/>
                  </StackPanel>
                </Border>
                <Border Background="#d1ffef" CornerRadius="4" Padding="10" Margin="0,5">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Бригада №2" FontWeight="Bold" Foreground="Black"/>
                    <TextBlock Text="8 вызовов" Foreground="#666" Margin="10,0,0,0"/>
                    <TextBlock Text="Свободна" Foreground="#4CAF50" FontWeight="Bold" Margin="10,0,0,0"/>
                  </StackPanel>
                </Border>
                <Border Background="#d1ffef" CornerRadius="4" Padding="10" Margin="0,5">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Бригада №3" FontWeight="Bold" Foreground="Black"/>
                    <TextBlock Text="15 вызовов" Foreground="#666" Margin="10,0,0,0"/>
                    <TextBlock Text="На месте" Foreground="#2196F3" FontWeight="Bold" Margin="10,0,0,0"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
        
        <!-- Actions Row -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
          <Button Content="Экспорт в PDF" Click="ExportPdf_Click" Background="White" Foreground="Black" 
                  BorderBrush="#333" Height="35" Padding="15,0" Margin="0,0,10,0" CornerRadius="4"/>
          <Button Content="Обновить данные" Click="Refresh_Click" Background="#2196F3" Foreground="White"
                  BorderBrush="#2196F3" Height="35" Padding="15,0" CornerRadius="4"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
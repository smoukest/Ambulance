<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="using:Ambulance.ViewModels"
			 xmlns:models="using:Ambulance.Models"
			 xmlns:icons="using:Material.Icons.Avalonia"
			 x:Class="Ambulance.DataGroupDisplay"
			 x:DataType="models:DataGroup"
			 >

	<Grid ColumnDefinitions="*, 50, 30, 30">

		<TextBlock Grid.Column="0" Text="{Binding Name}" />

		<TextBlock Grid.Column="1" Text="{Binding Count}" TextAlignment="Right" Padding="0,0,20,0" VerticalAlignment="Center" />

		<Border Grid.Column="2" Background="Transparent" ToolTip.Tip="Brief noch nicht gedruckt!" ToolTip.VerticalOffset="5" IsVisible="{Binding !Check1}">
			<icons:MaterialIcon  Kind="CheckboxBlankCircleOutline" />
		</Border>
		<Border Grid.Column="2" Background="Transparent" ToolTip.Tip="Brief bereits gedruckt!" ToolTip.VerticalOffset="5" IsVisible="{Binding Check1}">
			<icons:MaterialIcon Grid.Column="3" Kind="CheckCircleOutline" />
		</Border>

		<Border Grid.Column="3" Background="Transparent" ToolTip.Tip="Karte noch nicht gedruckt!" ToolTip.VerticalOffset="5" IsVisible="{Binding !Check2}">
			<icons:MaterialIcon Kind="CheckboxBlankCircleOutline" />
		</Border>
		<Border Grid.Column="3" Background="Transparent" ToolTip.Tip="Karte bereits gedruckt!" ToolTip.VerticalOffset="5" IsVisible="{Binding Check2}">
			<icons:MaterialIcon Grid.Column="4" Kind="CheckCircleOutline" />
		</Border>
	</Grid>
</UserControl>